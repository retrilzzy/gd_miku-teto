{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"version": "v0.1.0",
	"id": "retrilz.miku-teto",
	"name": "Miku & Teto Border",
	"developer": "retrilz",
	"description": "Adds a Miku & Teto border to every level!",
	"links": {
		"source": "https://github.com/retrilzzy/gd_miku-teto",
		"website": "https://rzx.ovh/"
	},
	"tags": [
		"customization",
		"joke"
	],
	"resources": {
		"sprites": [
			"resources/*.png"
		]
	},
	"settings": {
		"spacing": {
			"type": "int",
			"name": "Sprite Spacing",
			"description": "Spacing between sprites (lower = more sprites).",
			"default": 40
		},
		"sprite-size": {
			"type": "int",
			"name": "Sprite Size",
			"description": "Base size of the border sprites.",
			"default": 20
		},
		"margin": {
			"type": "int",
			"name": "Screen Margin",
			"description": "Distance from the screen edges.",
			"default": 15
		},
		"char-mode": {
			"type": "string",
			"name": "Character Mode",
			"description": "Which characters appear and where.",
			"default": "Fully Random",
			"one-of": [
				"Fully Random",
				"Alternating",
				"Miku Only",
				"Teto Only",
				"Left Teto / Right Miku",
				"Left Miku / Right Teto"
			]
		},
		"hype-strength": {
			"type": "int",
			"name": "Hype Strength (%)",
			"description": "Multiplier for rotational speed and pulse scale.",
			"default": 35
		}
	}
}
